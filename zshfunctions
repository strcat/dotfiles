function calendar() {
	if [[ ! -f /usr/bin/cal ]] ; then
		echo "Please install cal before trying to use it!"
		return
	fi
	if [[ "$#" = "0" ]] ; then
		/usr/bin/cal | egrep -C 40 --color "\<$(date +%e| tr -d ' ')\>"
